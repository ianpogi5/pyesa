{
  "name": "pyesa",
  "private": true,
  "version": "2.2.1",
  "type": "module",
  "scripts": {
    "dev": "npm run generate-data && vite --host",
    "build": "npm run generate-data && vite build --mode production",
    "lint": "eslint src/ server/ scripts/",
    "preview": "vite preview",
    "generate-data": "node scripts/generate-manifest.js && node scripts/generate-library.js && node scripts/generate-liturgy.js",
    "generate-manifest": "node scripts/generate-manifest.js",
    "generate-library": "node scripts/generate-library.js",
    "test-api": "node server/test/run.mjs",
    "deploy": "git pull --recurse-submodules && npm install && npm run build && pm2 restart pyesa",
    "e2e-api": "node e2e/local-api.mjs",
    "e2e": "node e2e/drive.mjs",
    "readme-shots": "node e2e/readme-shots.mjs"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "chordsheetjs": "^12.0.0",
    "idb": "^8.0.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-icons": "^5.4.0",
    "react-router-dom": "^7.1.5",
    "tailwindcss": "^4.2.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react-swc": "^3.5.0",
    "eslint": "^9.17.0",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "globals": "^15.14.0",
    "playwright-core": "^1.61.1",
    "romcal": "^1.3.0",
    "vite": "^6.0.5",
    "vite-plugin-pwa": "^0.21.1"
  }
}
